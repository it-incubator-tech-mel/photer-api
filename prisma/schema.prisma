generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  PERSONAL
  BUSINESS
}

model User {
  id                Int                @id @default(autoincrement())
  username          String             @db.VarChar(30)
  password          String?            @db.VarChar(255)
  email             String             @unique
  createdAt         DateTime           @default(now())
  isDeleted         Boolean            @default(false)
  updatedAt         DateTime           @updatedAt
  devices           Device[]
  emailConfirmation EmailConfirmation?
  providers         OAuthAccount[]
  passwordRecovery  PasswordRecovery?
  posts             Post[]
  accountType       AccountType        @default(PERSONAL)
  profile           Profile?
  subscription      Subscription?      @relation("UserSubscription")
}

model Profile {
  id        Int       @id @default(autoincrement())
  userId    Int       @unique
  firstName String    @db.VarChar(50)
  lastName  String    @db.VarChar(50)
  birthDate DateTime?
  country   String?   @db.VarChar(100)
  city      String?   @db.VarChar(100)
  aboutMe   String?   @db.VarChar(200)
  avatarUrl String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  isDeleted Boolean   @default(false)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([country])
  @@index([city])
  @@index([createdAt])
  @@index([birthDate])
}

model OAuthAccount {
  id         Int          @id @default(autoincrement())
  userId     Int
  provider   ProviderType
  providerId String
  email      String
  createdAt  DateTime     @default(now())
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
}

model EmailConfirmation {
  userId           Int      @id
  confirmationCode String   @unique
  expirationDate   DateTime
  isConfirmed      Boolean  @default(false)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordRecovery {
  userId         Int      @id
  recoveryCode   String   @unique
  expirationDate DateTime
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Device {
  id         String   @id @default(uuid())
  userId     Int
  deviceName String
  ip         String
  iat        DateTime @default(now())
  exp        DateTime @default(now())
  isDeleted  Boolean  @default(false)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Post {
  id          Int            @id @default(autoincrement())
  description String?        @db.VarChar(500)
  userId      Int
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  isDeleted   Boolean        @default(false)
  status      PostStatusType @default(public)
  photos      Photo[]
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Photo {
  id        Int      @id @default(autoincrement())
  photoUrl  String
  postId    Int
  createdAt DateTime @default(now())
  isDeleted Boolean  @default(false)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

enum ProviderType {
  GITHUB
  GOOGLE
}

enum PostStatusType {
  private
  public
}

enum SubscriptionStatus {
  ACTIVE
  PENDING
  EXPIRED
  CANCELED
}

enum PaymentProvider {
  STRIPE
  PAYPAL
}

model Subscription {
  id                Int               @id @default(autoincrement())
  userId            Int
  user              User              @relation("UserSubscription", fields: [userId], references: [id])
  status            SubscriptionStatus @default(PENDING)
  accountType       AccountType       @default(BUSINESS)
  validUntil        DateTime?
  autoRenewal       Boolean           @default(true)
  paymentProvider   PaymentProvider
  externalId        String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([userId])
  @@index([validUntil])
  @@index([status])
}